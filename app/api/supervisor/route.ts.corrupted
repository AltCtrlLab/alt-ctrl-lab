    console.log('
══════════════════════════════════════════════════════════════════
');
    
    // Extraire et logger le plan structuré
    const finalPlan = extractSupervisorPlan(finalDecision);
    console.log('[WarRoom] Plan structuré extrait:', JSON.stringify(finalPlan, null, 2));
    
    broadcastTaskUpdate({
      id: warRoomId,
