    const decisionPrompt = `Tu es AbdulHakim, CEO de Alt Ctrl Lab.

TES 3 VISIONS INITIALES:
${visionsText}

ÉVALUATION DU CTO (Matin - Critère Technique):
${matinEvaluation}

ÉVALUATION DU DA (Musawwir - Critère UX):
${musawwirEvaluation}

MISSION FINALE:
1. Analyse les notes et justifications de tes experts
2. Choisis LA meilleure vision (A, B ou C) OU propose un HYBRIDE
3. Génère LE PLAN D'ACTION FINAL sous forme de JSON strict:

{
  "diagnostic_implacable": "Analyse de la situation",
  "vision_long_terme_roi": "Vision à 3 ans",
  "vision_choisie": "A|B|C|HYBRIDE",
  "justification_decision": "Pourquoi cette vision",
  "actions": [
    {
      "agent_id": "musawwir|matin|fatah|hasib",
      "directive_top_1_percent": "Mission exacte",
      "angle_psychologique_ou_technique": "Approche",
      "livrable_attendu": "Résultat concret",
      "priority": "1|2|3"
    }
  ]
}

RÈGLE ABSOLUE: Réponds UNIQUEMENT avec le JSON valide, aucun texte avant/après.`;

    const { success: finalDecision_success, stdout: finalDecision } = await executeOpenClawAgent('abdulhakim', decisionPrompt, 180000);
    if (!finalDecision_success) throw new Error(`Agent failed: ${finalDecision}`);
    
    // 🎯 TÉLÉMÉTRIE: Log de la décision CEO
    console.log('
╔════════════════════════════════════════════════════════════════╗');
    console.log('║        🎯 DÉCISION CEO (Phase 3: Convergence)                   ║');
