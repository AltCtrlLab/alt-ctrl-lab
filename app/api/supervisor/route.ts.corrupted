        livrable_attendu: 'Implementation',
        priority: '1'
      }]
    };
    void runSequentialPipeline(fallbackPlan, teamMapping);
  }
}

/**
 * Helper: Appel agent Kimi générique
 */
async function executeOpenClawAgent(agentId: string, prompt: string, timeoutMs: number).then(r => r.success ? r.stdout : Promise.reject(new Error(r.stderr))): Promise<string> {
  const { spawn } = require('child_process');
  const os = require('os');
  const path = require('path');
  
  return new Promise((resolve, reject) => {
    const child = spawn('openclaw', [
      'agent',
      '--agent', agentId,
      '--message', prompt,
      '--local',
      '--timeout', String(Math.floor(timeoutMs / 1000))
    ], {
      cwd: path.join(os.homedir(), '.openclaw/workspace'),
      env: { ...process.env, FORCE_COLOR: '0' }
    });

    let stdout = '';
    let stderr = '';

    child.stdout.on('data', (data: Buffer) => { stdout += data.toString(); });
    child.stderr.on('data', (data: Buffer) => { stderr += data.toString(); });

    const timeout = setTimeout(() => {
      child.kill('SIGTERM');
      reject(new Error(`Timeout ${timeoutMs}ms`));
    }, timeoutMs);

    child.on('close', (code: number | null) => {
      clearTimeout(timeout);
      if (code !== 0) {
        reject(new Error(`Agent ${agentId} failed: ${stderr}`));
      } else {
        resolve(stdout.trim());
      }
    });

    child.on('error', (err: Error) => { reject(err); });
  });
}
async function runSequentialPipeline(
  plan: { actions: any[] }, 
  teamMapping: Record<string, string>
): Promise<void> {
  let accumulatedContext = "";
  
  for (const action of plan.actions) {
    const directorId = action.agent_id;
    const executorId = teamMapping[directorId];
    
    if (!executorId) {
      console.error(`[Pipeline] No executor mapping for director ${directorId}`);
      break;
    }

    const taskId = `pipe_${Date.now()}_${Math.random().toString(36).substring(2, 9)}`;
    
    // Enrichissement du brief avec contexte hérité
    const enrichedBrief = `${action.directive_top_1_percent}

ANGLE/ARCHITECTURE: ${action.angle_psychologique_ou_technique}

LIVRABLE ATTENDU: ${action.livrable_attendu}

${accumulatedContext ? `--- CONTEXTE HÉRITÉ DES ÉTAPES PRÉCÉDENTES ---
${accumulatedContext}` : ''}`;

    try {
      await createTask({
        id: taskId,
        agentName: `${directorId}→${executorId}`,
        prompt: enrichedBrief,
      });

      console.log(`[Pipeline] Launching: ${directorId} → ${executorId} (task: ${taskId})`);

      // ⭐ Lancement avec await pour séquentialité, mais cette fonction est détachée
      await executeHierarchicalTask(
        taskId, 
        directorId, 
        executorId, 
        enrichedBrief,
        undefined,  // serviceId
        900000  // 15 minutes
      );

      // Vérifier le résultat après exécution
      const { getTask } = await import('@/lib/db');
      const task = await getTask(taskId);

      if (task?.status === 'COMPLETED' && task.result) {
        accumulatedContext += `

--- LIVRABLE DE ${directorId} ---
${task.result.substring(0, 5000)}`;
        console.log(`[Pipeline] ✅ ${directorId} completed, context accumulated`);
      } else if (task?.status === 'FAILED' || task?.status === 'FAILED_QA' || (task?.status as string) === 'FATAL_ERROR') {
        console.error(`[Pipeline] ❌ ${directorId} failed: ${task.error || 'Unknown error'}`);
        break; // Circuit breaker
      }
    } catch (error) {
      console.error(`[Pipeline] ❌ Error in ${directorId}→${executorId}:`, error);
      break;
    }
  }
  
  console.log('[Pipeline] 🎉 Pipeline completed or stopped');
}

/**
 * GET /api/supervisor - Info
 */
export async function GET() {
  return NextResponse.json({
    service: 'Alt Ctrl Lab Supervisor',
    version: '2.0.0',
    architecture: 'Sequential Pipeline with Hierarchical Mapping',
    team_mapping: TEAM_MAPPING,
    features: [
      'Séquentiel strict (for...of)',
      'Transfert de contexte entre étapes',
      'Circuit breaker sur échec',
      'QA Loop intégrée (5 min timeout)',
      '9 agents distincts (4D + 4E + 1CEO)'
    ]
  });
}
